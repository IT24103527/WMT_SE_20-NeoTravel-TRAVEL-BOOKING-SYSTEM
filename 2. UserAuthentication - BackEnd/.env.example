# Copy this to .env and fill in real values
# On AWS Elastic Beanstalk, set these as Environment Properties (not .env file)

PORT=8080
NODE_ENV=production

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/neotravel?retryWrites=true&w=majority

# JWT secrets — use long random strings in production
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=15m
REFRESH_SECRET=replace_with_different_64_char_random_string

# Gmail App Password (not your real password — generate at myaccount.google.com/apppasswords)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=https://your-eb-url.elasticbeanstalk.com,exp://your-expo-url
